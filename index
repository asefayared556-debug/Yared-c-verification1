    // Form submission handler
    document.addEventListener('DOMContentLoaded', function() {
        const form = document.querySelector('form.form-inline');
        if (form) {
            form.addEventListener('submit', function(e) {
                e.preventDefault();
                
                const input = this.querySelector('input[name="cert_no"]');
                const certNumber = input.value.trim();
                
                // Find certificate
                const certificate = certificateDB.find(cert => cert.controlNumber === certNumber);
                
                // Remove existing result if any
                const existingResult = document.getElementById('cert-verification-result');
                if (existingResult) {
                    existingResult.remove();
                }
                
                // Create result element
                const resultDiv = document.createElement('div');
                resultDiv.id = 'cert-verification-result';
                resultDiv.style.marginTop = '20px';
                resultDiv.style.padding = '10px';
                resultDiv.style.borderRadius = '5px';
                
                if (certificate) {
                    // Valid certificate
                    resultDiv.style.backgroundColor = '#EBEBEB';
                    resultDiv.style.border = '1px solid #c3e6cb';
                    resultDiv.style.color = '#155724';
                    
                    let html = `
                        <h4 style="margin-bottom: 15px;"> CERTIFICATE IS VALID!</h4>
                        <table style="width: 100%; border-collapse: collapse;">
                            <tr><td style="padding: 8px 0;"><strong>Control Number:</strong></td><td style="padding: 8px 0;"><span style="font-family: "Monstserrat", 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; font-size: 24px; font-weight: bold; color: #000; background: #e6f3ff; padding: 2px 8px; border-radius: 4px;">${certificate.controlNumber}</span></td>
                            <tr><td style="padding: 8px 0;"><strong>Certificate Number:</strong></td><td>${certificate.certificateNumber}</td></tr>
                            <tr><td style="padding: 8px 0;"><strong>Full Name:</strong></td><td>${certificate.fullName}</td></tr>
                            <tr><td style="padding: 8px 0;"><strong>Gender:</strong></td><td>${certificate.gender}</td></tr>
                            <tr><td style="padding: 8px 0;"><strong>Occupation:</strong></td><td>${certificate.occupation}</td></tr>
                            <tr><td style="padding: 8px 0;"><strong>Level:</strong></td><td>${certificate.level}</td></tr>
                            <tr><td style="padding: 8px 0;"><strong>Issue Date:</strong></td><td>${certificate.issueDate}</td></tr>
                            <tr><td style="padding: 8px 0;"><strong>Expire Date:</strong></td><td>${certificate.expireDate}</td></tr>
                            <tr><td style="padding: 8px 0;"><strong>Status:</strong></td><td><span style="background: #'; color: black; padding: 3px 10px; border-radius: 3px;">${certificate.status}</span></td></tr>
                        </table>
     
                    `;
                    resultDiv.innerHTML = html;
                } else {
                    // Invalid certificate
                    resultDiv.style.backgroundColor = '#f8d7da';
                    resultDiv.style.border = '1px solid #f5c6cb';
                    resultDiv.style.color = '#721c24';
                    
                    resultDiv.innerHTML = `
                        <h4 style="margin-bottom: 10px;">❌ Certificate Not Found</h4>
                        <p>The control number "${certNumber}" could not be verified in our database.</p>
                        <p style="margin-bottom: 0;">Please check the number and try again.</p>
                    `;
                }
                
                // Insert result after the form
                form.parentNode.appendChild(resultDiv);
            });
        }
    });
</script>

